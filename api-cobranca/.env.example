# ============================================
# API-COBRANCA (NestJS backend)
# ============================================
# Copie para .env e preencha. Não commitar .env com valores reais.

# Ambiente
NODE_ENV=development

# Porta HTTP do Nest (padrão 3001, front-cobranca usa 3000)
PORT=3001

# Connection string do Neon Database (mesma usada pelo front-cobranca)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Base URL da Evolution API (default: Docker local)
EVOLUTION_API_URL="http://localhost:8080"
