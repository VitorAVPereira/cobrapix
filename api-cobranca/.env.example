# ============================================
# API-COBRANCA (NestJS backend)
# ============================================
# Copie para .env e preencha. Não commitar .env com valores reais.

# Ambiente
NODE_ENV=development

# Porta HTTP do Nest (padrão 3001, front-cobranca usa 3000)
PORT=3001

# ============================================
# PostgreSQL (Docker local - recomendado para desenvolvimento)
# ============================================
# Se usando Docker local (definido no docker-compose.yml)
DATABASE_URL="postgresql://cobrapix:cobrapix_password@localhost:5432/cobrapix"
# URL direta para Prisma (sem pool de conexão)
DIRECT_URL="postgresql://cobrapix:cobrapix_password@localhost:5432/cobrapix"

# Variáveis do Docker (opcional - para docker-compose)
# POSTGRES_USER=cobrapix
# POSTGRES_PASSWORD=cobrapix_password
# POSTGRES_DB=cobrapix

# ============================================
# Meta Cloud API (WhatsApp oficial)
# ============================================
# Configure as credenciais por empresa em /whatsapp/meta.
# O webhook oficial deve apontar para: https://sua-api.com/webhooks/meta
META_GRAPH_API_VERSION="v23.0"
META_WEBHOOK_VERIFY_TOKEN="change_me_meta_verify_token"
META_WEBHOOK_BASE_URL="https://your-public-api-url.com"
META_APP_SECRET="your_meta_app_secret"

# Evolution API legado (opcional, mantido apenas para migração)
# EVOLUTION_API_URL="http://localhost:8080"
# EVOLUTION_API_KEY="evolution_api_key_secret_change_in_production"
# EVOLUTION_JWT_SECRET="jwt_secret_change_in_production"

# ============================================
# Efi Bank (Gateway de Pagamento - PIX CobV/Bolix)
# ============================================
EFI_ENV="homologation"
EFI_PLATFORM_CLIENT_ID="your_efi_platform_client_id"
EFI_PLATFORM_CLIENT_SECRET="your_efi_platform_client_secret"
EFI_PLATFORM_CERT_PATH="C:\\certs\\efi-homologacao.p12"
EFI_PLATFORM_CERT_PASSWORD="your_efi_certificate_password"
EFI_PLATFORM_PAYEE_CODE="your_platform_payee_code"
EFI_PLATFORM_ACCOUNT_NUMBER="your_platform_account_number"
EFI_PLATFORM_SPLIT_PERCENTAGE=0
EFI_WEBHOOK_BASE_URL="https://your-public-api-url.com"
PAYMENT_SECRET_KEY="change_me_with_at_least_32_characters"

# ============================================
# Redis (para filas BullMQ)
# ============================================
# Instância Redis para filas de mensagens (use Docker, Upstash, etc)
REDIS_HOST="localhost"
REDIS_PORT=6379
# REDIS_PASSWORD="your_redis_password"  # opcional

# ============================================
# Autenticação
# ============================================
AUTH_SECRET="your_auth_secret_generate_with_openssl"

# ============================================
# CORS
# ============================================
# Frontend URLs separadas por vírgula
ALLOWED_ORIGINS="http://localhost:3000"
